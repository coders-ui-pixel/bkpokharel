# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# MySQL connection string used by Prisma
DATABASE_URL="mysql://root:password@localhost:3306/mcq_platform"

# JWT secrets (use long random strings in real use)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Local file storage
UPLOAD_DIR=./uploads

# Gmail SMTP for password-reset emails (leave blank to just log the reset link to the console)
GMAIL_USER=
GMAIL_APP_PASSWORD=
PASSWORD_RESET_EXPIRES_IN=1h

# ---- Client (Vite reads VITE_ prefixed vars from client/.env) ----
VITE_API_URL=http://localhost:4000/api
VITE_API_ORIGIN=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
