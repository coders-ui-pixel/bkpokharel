{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:codegen": "kysely-codegen --dialect mysql --camel-case --type-mapping \"{\\\"tinyint\\\":\\\"boolean\\\"}\" --exclude-pattern \"_prisma_migrations|schema_migrations\" --out-file src/config/db-types.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.29.4",
    "multer": "^2.2.0",
    "mysql2": "^3.23.1",
    "nodemailer": "^9.0.3",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
